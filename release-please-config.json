{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "skills",
      "include-component-in-tag": false,
      "changelog-type": "github",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[0].version"
        },
        {
          "type": "json",
          "path": "plugins/argo-rollouts/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "plugins/argo-rollouts/skills/argo-rollouts/SKILL.md"
        }
      ]
    }
  }
}
