# EditorConfig — https://editorconfig.org
# Keeps file encoding, line endings, and indentation consistent across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
# Trailing whitespace can be significant in Markdown (two-space hard breaks).
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_size = 2
